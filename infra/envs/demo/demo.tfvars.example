# Copy to demo.tfvars (gitignored). Holds ONLY the secret / per-user value.
#
# The shared non-secret toggles (enable_waf, enable_cicd, api_desired_count)
# live in the committed common.tfvars, which local and CI both read - so this
# file is intentionally just the one value that must not be committed.
#
# Empty string disables the SNS alarm subscription.
alert_email = "you@example.com"
